{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SkillRadar": "Host=localhost;Port=5433;Database=skillradar;Username=skillradar;Password=skillradar"
  },
