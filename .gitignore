# Python (active product at repo root)
__pycache__/
*.py[cod]
.venv/
.dbtvenv/        # isolated Python 3.12 env for dbt (dbt-core doesn't support 3.14 yet)
.env
*.egg-info/
.pytest_cache/
.ruff_cache/

# uv
uv.lock

# dbt (transform/) — build artifacts, fetched packages, logs; the project source is committed
transform/target/
transform/dbt_packages/
transform/logs/
transform/.user.yml

# Archived .NET implementation — preserved at the git tag `dotnet-archive`, not shipped on main
reference/dotnet-original/

# Data outputs (the pipeline regenerates these; CI may commit them instead)
data/bronze/*.parquet
data/gold/*.parquet
data/*.duckdb
data/*.duckdb.wal
data/roadmap_cache/

# Keep the seed inputs and the data dir structure
!data/sources.json
!data/skills.seed.json
# Note: data/serving.duckdb (the slim DB Streamlit Cloud serves) stays ignored too — it is a
# generated data artifact, not source. The daily CI pipeline force-commits it; humans don't.

